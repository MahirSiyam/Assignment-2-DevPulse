# Local development only — gitignored, never commit.
# Production: set these in your platform (Neon, Railway, Render, etc.)

PORT=3000
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT — access token
JWT_ACCESS_SECRET=your_access_token_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m

# JWT — refresh token
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
